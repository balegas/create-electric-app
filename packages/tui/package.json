		"marked-terminal": "^7.3.0",
		"meow": "^13.0.0",
		"react": "^18.3.1"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^18.3.0",
		"typescript": "^5.8.0"
	}
