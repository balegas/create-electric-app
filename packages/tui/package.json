{
	"name": "@electric-agent/tui",
	"version": "0.1.1",
	"description": "Terminal UI for Electric Agent Studio",
	"repository": {
		"type": "git",
		"url": "https://github.com/balegas/create-electric-app",
		"directory": "packages/tui"
	},
	"type": "module",
	"main": "./dist/index.js",
