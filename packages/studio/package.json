{
	"name": "@electric-agent/studio",
	"version": "1.10.0",
	"description": "General-purpose agent studio — web UI, sandbox management, session bridges",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./streams": {
			"types": "./dist/streams.d.ts",
			"import": "./dist/streams.js"
		},
		"./sessions": {
			"types": "./dist/sessions.d.ts",
			"import": "./dist/sessions.js"
		},
		"./sandbox": {
			"types": "./dist/sandbox/index.d.ts",
			"import": "./dist/sandbox/index.js"
		},
		"./sandbox/*": {
			"types": "./dist/sandbox/*.d.ts",
			"import": "./dist/sandbox/*.js"
		},
		"./bridge": {
			"types": "./dist/bridge/index.d.ts",
			"import": "./dist/bridge/index.js"
		},
		"./shared-sessions": {
			"types": "./dist/shared-sessions.d.ts",
			"import": "./dist/shared-sessions.js"
		},
		"./room-registry": {
			"types": "./dist/room-registry.d.ts",
			"import": "./dist/room-registry.js"
		},
		"./active-sessions": {
			"types": "./dist/active-sessions.d.ts",
			"import": "./dist/active-sessions.js"
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "tsc && pnpm run build:web",
		"build:server": "tsc",
		"build:web": "vite build --config client/vite.config.ts",
		"typecheck": "tsc --noEmit",
		"dev": "tsc --watch",
		"dev:web": "vite --config client/vite.config.ts",
		"test": "node --import tsx --test tests/*.test.ts",
		"dev:proxy": "caddy run --config Caddyfile --watch",
		"clean": "rm -rf dist"
	},
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@electric-agent/protocol": "workspace:*",
		"@durable-streams/client": "^0.2.1",
		"@durable-streams/server": "^0.2.1",
		"@fly/sprites": "^0.0.1",
		"@hono/node-server": "^1.19.9",
		"hono": "^4.11.9"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-router-dom": "^5.3.3",
		"@vitejs/plugin-react": "^5.1.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hot-toast": "^2.6.0",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.13.0",
		"remark-gfm": "^4.0.1",
		"sugar-high": "^0.9.5",
		"dotenv": "^17.3.1",
		"tsx": "^4.19.0",
		"typescript": "^5.8.0",
		"undici": "^7.22.0",
		"vite": "^7.3.1"
	}
}
