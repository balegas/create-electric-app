# Minimal test sandbox for integration testing.
# Communicates via hosted Durable Streams (reads commands, writes events back).
#
# Required env vars: DS_URL, DS_SERVICE_ID, DS_SECRET, SESSION_ID
#
# Build:
#   docker build -f Dockerfile.test-sandbox -t electric-agent-test-sandbox .
# Push:
#   docker tag electric-agent-test-sandbox $DOCKER_HUB_USER/electric-agent-test-sandbox
#   docker push $DOCKER_HUB_USER/electric-agent-test-sandbox

FROM node:22-slim

RUN npm install -g tsx

WORKDIR /home/agent
COPY tests/test-sandbox-agent.ts /home/agent/agent.ts
RUN echo '{"name":"test-sandbox","type":"module","private":true}' > package.json && \
    npm install @durable-streams/client

ENTRYPOINT ["tsx", "/home/agent/agent.ts"]
