# Minimal test sandbox for integration testing.
# Runs a Node.js script that:
#   --stdio mode:  reads NDJSON from stdin, echoes events to stdout
#   --stream mode: reads from durable stream, writes events back
#
# Build:
#   docker build -f Dockerfile.test-sandbox -t electric-agent-test-sandbox .

FROM node:22-slim

RUN npm install -g tsx

WORKDIR /home/agent
COPY tests/test-sandbox-agent.ts /home/agent/agent.ts

# Default: stdio mode
ENTRYPOINT ["tsx", "/home/agent/agent.ts"]
CMD ["--stdio"]
